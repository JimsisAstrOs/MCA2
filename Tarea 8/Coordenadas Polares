import numpy as np
import matplotlib.pyplot as plt

valores_h = [1,2,3,4,5,6]

for h in valores_h:

    theta = np.linspace(0, 2*np.pi, 4000)

    r = 3*np.cos(h*theta)

    x = r*np.sin(theta)
    y = r*np.cos(theta)

    plt.figure(figsize=(4,4))

    plt.plot(x,y)

    plt.axis('equal')
    plt.title(f"h = {h}")

    plt.show()
